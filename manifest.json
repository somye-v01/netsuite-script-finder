{
  "manifest_version": 3,
  "name": "NetSuite Script Finder",
  "version": "1.0.0",
  "description": "Instantly see all script deployments on any NetSuite record, with author, entry points, and the ability to toggle scripts active or inactive.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "NetSuite Script Finder"
  },
  "permissions": [
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "https://*.netsuite.com/*",
    "https://*.app.netsuite.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.netsuite.com/*",
        "https://*.app.netsuite.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["styles.css"],
      "matches": ["https://*.netsuite.com/*", "https://*.app.netsuite.com/*"]
    }
  ]
}
